Subject: [PATCH 076/120] check cache location mask when dcp_world_size > 1

---
 python/sglang/srt/mem_cache/memory_pool.py | 10 +++++-----
 1 file changed, 5 insertions(+), 5 deletions(-)

diff --git a/python/sglang/srt/mem_cache/memory_pool.py b/python/sglang/srt/mem_cache/memory_pool.py
index c60463092fbf..7fff28f0df07 100644
--- a/python/sglang/srt/mem_cache/memory_pool.py
+++ b/python/sglang/srt/mem_cache/memory_pool.py
@@ -1557,11 +1557,11 @@ def set_kv_buffer(
     ):
         layer_id = layer.layer_id
         assert not self.nsa_kv_cache_store_fp8
-
-        valid_mask = loc % get_dcp_world_size() == get_dcp_rank()
-        if not valid_mask.all():
-            loc = loc[valid_mask]
-            cache_k = cache_k[valid_mask]
+        if get_dcp_world_size() > 1:
+            valid_mask = loc % get_dcp_world_size() == get_dcp_rank()
+            if not valid_mask.all():
