+    pid_blk = tl.program_id(1)
+
+    dcp_mask = tl.load(dcp_kv_mask_ptr + pid_loc)
+
+    # Skip write if mask is 0
+    if dcp_mask == 0:
+        return
+
+    base = pid_blk * BLOCK
+    offs = base + tl.arange(0, BLOCK)
+    total_dim = nope_dim + rope_dim
+    mask = offs < total_dim
