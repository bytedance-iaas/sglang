+    def _cuda_free_bytes(self) -> int:
+        """查询当前设备上 GPU 的空闲显存（byte）。"""
+        try:
+            free, _total = torch.cuda.mem_get_info(self.device)
+            return int(free)
+        except Exception:
+            return -1
